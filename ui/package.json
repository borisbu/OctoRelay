{
  "name": "octorelay-ui",
  "description": "The UI scripts for OctoRelay plugin",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "author": {
    "name": "Anna Bocharova",
    "url": "https://github.com/RobinTail"
  },
  "license": "AGPL-3.0-only",
  "scripts": {
    "lint": "eslint",
    "test": "tsc --noEmit && TZ=UTC vitest run --coverage --exclude qa*",
    "build": "yarn build:js && yarn build:styles && yarn build:qa",
    "build:js": "tsup",
    "build:styles": "lessc styles/octorelay.less ../octoprint_octorelay/static/css/octorelay.css",
    "build:qa": "vitest run qa.spec.ts"
  },
  "dependencies": {},
  "devDependencies": {
    "@tsconfig/node20": "^20.1.6",
    "@types/jquery": "^3.5.33",
    "@types/lodash": "^3.10.9",
    "@types/node": "^24.10.4",
    "@vitest/coverage-istanbul": "^3.2.4",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-allowed-dependencies": "^2.0.1",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-unicorn": "^56.0.1",
    "happy-dom": "^16.8.1",
    "less": "^4.4.1",
    "mockdate": "^3.0.5",
    "prettier": "3.6.2",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.45.0",
    "vitest": "^3.2.4"
  },
  "packageManager": "yarn@1.22.22+sha1.ac34549e6aa8e7ead463a7407e1c7390f61a6610"
}
